modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'PORT=8080 pnpm --filter @workspace/api-server run dev & PORT=5000 pnpm --filter @workspace/marketplace run dev'"
waitForPort = 5000

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git push https://Firitol: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@github.com/Firitol/E-Marcato.git main && echo 'PUSH COMPLETE'"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 20787
externalPort = 3003

[[ports]]
localPort = 20788
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "pnpm --filter @workspace/db run push-force && PORT=8080 node artifacts/api-server/dist/index.js"]
build = ["bash", "-c", "pnpm install && pnpm --filter @workspace/marketplace run build && pnpm --filter @workspace/api-server run build"]

[userenv]

[userenv.shared]
JWT_SECRET = "32bc342e098e73086941da73c2c0d6ae92a3bfe7cd8c9e8382c7027a397a303c"
